# Composer
/vendor/
# NOTE: composer.lock is intentionally committed. Drupal *site* repos must
# commit it so `composer audit --locked` (used by the security job) and
# reproducible installs work. Only contrib libraries should ignore it.

# PHPUnit / PHPStan caches
.phpunit.result.cache
.phpunit.cache/
.phpstan-cache/
phpstan-baseline.neon

# Local overrides — keep .dist in git, ignore the unsuffixed copy
/phpstan.neon
/phpcs.xml
/phpunit.xml

# DDEV
.ddev/.dbimports/
.ddev/import-db/
.ddev/db_snapshots/
.ddev/.global_commands/

# Editors
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local examples / scratch
/tmp/
/local/
